{
  "name": "@instantphoto/react",
  "version": "0.4.1",
  "description": "React components for instant film photo effects using WebGL",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src stories",
    "lint:fix": "eslint src stories --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:ci": "bun run lint && bun run typecheck && bun run test:coverage && bun run build && bun run build-storybook && bun run test:e2e",
    "release": "changeset publish",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.60.0",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/addon-mcp": "^0.7.0",
    "@storybook/react-vite": "10.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "10.5.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "serve": "^14.2.6",
    "storybook": "10.5.3",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "polaroid",
    "instant-photo",
    "instax",
    "react",
    "film",
    "photo",
    "effects",
    "webgl",
    "canvas",
    "filter"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/milankappen/instantphoto.git"
  },
  "homepage": "https://github.com/milankappen/instantphoto#readme",
  "bugs": {
    "url": "https://github.com/milankappen/instantphoto/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
