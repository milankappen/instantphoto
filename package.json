{
  "name": "@instantphoto/react",
  "version": "0.4.0",
  "description": "React components for instant film photo effects using WebGL",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src stories",
    "lint:fix": "eslint src stories --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "release": "changeset publish",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "serve": "^14.2.5",
    "storybook": "^8.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "polaroid",
    "instant-photo",
    "instax",
    "react",
    "film",
    "photo",
    "effects",
    "webgl",
    "canvas",
    "filter"
  ],
  "license": "MIT",
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/milankappen/instantphoto.git"
  },
  "homepage": "https://github.com/milankappen/instantphoto#readme",
  "bugs": {
    "url": "https://github.com/milankappen/instantphoto/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
